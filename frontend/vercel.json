{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://portfolio-v1-production.up.railway.app/api/:path*"
    },
    {
      "source": "/media/:path*",
      "destination": "https://portfolio-v1-production.up.railway.app/media/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}