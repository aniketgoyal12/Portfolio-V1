# Django Security
SECRET_KEY=your-production-secret-key
DEBUG=False
ALLOWED_HOSTS=your-railway-app-domain.up.railway.app,localhost,127.0.0.1

# Cookie Security (Default to True in production)
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SIMPLE_JWT_COOKIE_SECURE=True

# CORS & CSRF Origins (comma-separated URLs)
CORS_ALLOWED_ORIGINS=https://your-vercel-app.vercel.app,http://localhost:5173
CSRF_TRUSTED_ORIGINS=https://your-vercel-app.vercel.app,http://localhost:5173

# Railway MySQL Configuration
# If MYSQL_URL is set, it overrides the individual DB_* variables.
MYSQL_URL=mysql://root:password@host:port/database

# Individual Database settings (fallback if MYSQL_URL is not set)
DB_NAME=your_database_name
DB_USER=root
DB_PASSWORD=your_password
DB_HOST=your_host
DB_PORT=3306

# SMTP Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com
OWNER_EMAIL=your-email@gmail.com
